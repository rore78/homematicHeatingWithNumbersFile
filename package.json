{
  "name": "my-homematic-addon",
  "version": "1.0.0",
  "description": "Homematic IP Addon für Gerätesteuerung (Cloud und Local)",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "server": "node server.js",
    "example": "node examples/basic-usage.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "homematic",
    "homematic-ip",
    "smart-home",
    "automation"
  ],
  "author": "Roman Redlberger <roman@redlberger.com> 2025/11/25",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.14.2",
    "xmlrpc": "^1.3.2",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "xlsx": "^0.18.5",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "vitest": "^3.2.1",
    "@vitest/coverage-v8": "^3.2.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0"
  }
